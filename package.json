{
  "name": "oh-blog-analyzer",
  "version": "1.0.0",
  "main": "electron-main.js",
  "scripts": {
    "dev": "concurrently \"npm run client\" \"npm run electron\"",
    "client": "cd client && npm run dev",
    "electron": "wait-on http://localhost:5173 && electron .",
    "build": "cd client && npm run build",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.ohblog.analyzer",
    "productName": "OH BLOG",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "electron-main.js",
      "server/**/*",
      "client/dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "electron-is-dev": "^2.0.0",
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  }
}
